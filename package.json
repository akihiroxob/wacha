{
  "name": "wacha",
  "version": "1.0.0",
  "description": "Worker Aggregation and Control Hub for Agents",
  "homepage": "https://github.com/akihiroxob/wacha#readme",
  "bugs": {
    "url": "https://github.com/akihiroxob/wacha/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/akihiroxob/wacha.git"
  },
  "license": "MIT",
  "author": "",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "start": "tsx src/server.ts",
    "prestart": "postcss src/views/css/style.css -o public/css/style.css",
    "test": "mkdir -p .tmp && rm -f .tmp/wacha-test.db && WACHA_DB_PATH=.tmp/wacha-test.db node --import tsx --test --test-concurrency=1 test/**/*.test.ts",
    "dev": "npm-run-all --parallel dev:server dev:css",
    "dev:server": "tsx watch src/server.ts",
    "dev:css": "postcss src/views/css/style.css -o public/css/style.css --watch"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/better-sqlite3": "^7.6.13",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.8",
    "postcss-cli": "^11.0.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.12",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.8.0",
    "clsx": "^2.1.1",
    "hono": "^4.12.9",
    "kysely": "^0.28.15",
    "tsx": "^4.21.0",
    "zod": "^4.3.6"
  }
}
