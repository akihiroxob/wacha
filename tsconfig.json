{
  "compilerOptions": {
    "strict": true,
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "rootDir": ".",
    "baseUrl": "src",
    "ignoreDeprecations": "6.0",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "paths": {
      "@container": [
        "container.ts"
      ],
      "@application/*": [
        "application/*"
      ],
      "@constants/*": [
        "constants/*"
      ],
      "@mcp/*": [
        "mcp/*"
      ],
      "@domain/*": [
        "domain/*"
      ],
      "@repository/*": [
        "infrastructure/repository/*"
      ],
      "@database/*": [
        "infrastructure/database/*"
      ],
      "@bootstrap/*": [
        "bootstrap/*"
      ],
      "@tool/*": [
        "presentation/tool/*"
      ],
      "@controller/*": [
        "presentation/controller/*"
      ],
      "@views/*": [
        "views/*"
      ],
      "@utils/*": [
        "utils/*"
      ]
    },
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "test/**/*.ts",
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}